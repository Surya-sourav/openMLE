{
  "name": "data-sage-desktop",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "npm-run-all --parallel dev:react dev:electron",
    "dev:react": "vite",
    "dev:electron": "npm run transpile:electron && npm run copy:migrations && cross-env NODE_ENV=development electron . --no-sandbox",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "transpile:electron": "tsc -p src/electron/tsconfig.json",
    "copy:migrations": "mkdir -p dist-electron/internal-database/migrations && cp -r src/electron/internal-database/migrations/* dist-electron/internal-database/migrations/ 2>/dev/null || true && mkdir -p dist-electron/electron/internal-database/migrations && cp -r src/electron/internal-database/migrations/* dist-electron/electron/internal-database/migrations/ 2>/dev/null || true && mkdir -p dist-electron/kb && cp -r resources/kb/* dist-electron/kb/ 2>/dev/null || true",
    "dist:mac": "npm run transpile:electron && npm run copy:migrations && npm run build && electron-builder --mac --arm64",
    "dist:win": "npm run transpile:electron && npm run copy:migrations && npm run build && electron-builder --win --x64",
    "dist:linux": "npm run transpile:electron && npm run copy:migrations && npm run build && electron-builder --linux --x64",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.2",
    "@anthropic-ai/sdk": "^0.54.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.0.0",
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/client-sagemaker": "^3.0.0",
    "@azure/identity": "^4.0.0",
    "@google-cloud/aiplatform": "^3.0.0",
    "@libsql/client": "^0.15.15",
    "@mastra/core": "^0.24.9",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.1.17",
    "@tanstack/react-query": "^5.90.11",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "ai": "^6.0.3",
    "better-sqlite3": "^12.4.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.44.7",
    "get-port": "^7.1.0",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.554.0",
    "monaco-editor": "^0.55.1",
    "openai": "^6.9.1",
    "papaparse": "^5.5.3",
    "pg": "^8.16.3",
    "prettier": "^3.7.4",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-is": "^19.2.5",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^3.0.6",
    "recharts": "^3.8.1",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "ssh2": "^1.16.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.17",
    "vectordb": "^0.4.20",
    "ws": "^8.18.2",
    "xlsx": "^0.18.5",
    "zod": "^4.2.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@tanstack/eslint-plugin-query": "^5.91.2",
    "@tanstack/react-query-devtools": "^5.91.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.4",
    "@types/papaparse": "^5.3.15",
    "@types/pg": "^8.15.6",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@types/sqlite3": "^3.1.11",
    "@types/ssh2": "^1.15.5",
    "@types/ws": "^8.5.14",
    "@vitejs/plugin-react": "^5.0.4",
    "babel-plugin-react-compiler": "^19.1.0-rc.3",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.7",
    "electron": "^39.1.1",
    "electron-builder": "^26.0.12",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^16.4.0",
    "mastra": "^0.18.9",
    "npm-run-all": "^4.1.5",
    "patch-package": "^8.0.1",
    "shadcn": "^3.5.0",
    "tsx": "^4.20.6",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.45.0",
    "vite": "^7.1.7"
  },
  "build": {
    "appId": "com.datasage.desktop",
    "productName": "data-sage-desktop",
    "files": [
      "dist-electron/**/*",
      "dist-react/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist-electron/internal-database/migrations",
        "to": "app/dist-electron/internal-database/migrations",
        "filter": [
          "**/*.sql",
          "**/*.json"
        ]
      },
      {
        "from": "resources/kb",
        "to": "kb",
        "filter": [
          "**/*.md"
        ]
      },
      {
        "from": "src/main/python/scripts",
        "to": "python",
        "filter": [
          "**/*.py"
        ]
      }
    ],
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
